BASE_IMAGE_EXTRACTOR ?= ${BASE_IMAGE_EXTRACTOR}
BASE_IMAGE ?= ${BASE_IMAGE}
ROCM_VERSION ?= ${ROCM_VERSION}
AMDGPU_DRIVER_VERSION ?= ${AMDGPU_DRIVER_VERSION}
OS_DISTRO ?= ${OS_DISTRO}
OS_VERSION_ID ?= ${OS_VERSION_ID}

CONTAINER_MANAGER ?= podman 

IMAGE_REGISTRY_ORG ?=
IMAGE_REGISTRY_NAMESPACE ?=

ifndef IMAGE_REGISTRY_ORG
$(error MISSING "IMAGE_REGISTRY_ORG" value)
endif

ifndef IMAGE_REGISTRY_NAMESPACE
$(error MISSING "IMAGE_REGISTRY_NAMESPACE" value)
endif

CONTAINERFILE_EXTRACTOR=Containerfile.amdgpu-dkms-extractor

.PHONY: image-extractor

image-extractor:
	$(CONTAINER_MANAGER) build -f $(CONTAINERFILE_EXTRACTOR) -t $(IMAGE_REGISTRY_ORG)/$(IMAGE_REGISTRY_NAMESPACE):rocm$(ROCM_VERSION)-$(OS_DISTRO)$(OS_VERSION_ID) \
		--build-arg BASE_IMAGE_EXTRACTOR=$(BASE_IMAGE_EXTRACTOR) \
		--build-arg BASE_IMAGE=$(BASE_IMAGE) \
		--build-arg ROCM_VERSION=$(ROCM_VERSION) \
		--build-arg AMDGPU_DRIVER_VERSION=$(AMDGPU_DRIVER_VERSION) \
		--build-arg OS_DISTRO=$(OS_DISTRO) \
		--build-arg OS_VERSION_ID=$(OS_VERSION_ID)
